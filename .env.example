# ── Backend ────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically from the PostgreSQL addon.
# Format: postgresql://user:pass@host:port/dbname
# (App transforms it to postgresql+asyncpg:// automatically)
DATABASE_URL=postgresql://user:password@host:5432/railway

# Set to true if Railway PostgreSQL requires SSL
DATABASE_SSL=false

# Allowed CORS origins — set to your Railway frontend URL, or * for all
CORS_ORIGINS=https://your-frontend.up.railway.app

# Optional: Reddit OAuth (social tab)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=WarRoom/1.0

# Optional: paid API keys
GUARDIAN_API_KEY=
NEWSDATA_API_KEY=
ALPHA_VANTAGE_KEY=

# Railway sets PORT automatically — the port uvicorn binds to
PORT=8000


# ── Frontend (nginx env vars) ───────────────────────────────────
# PORT: Railway injects this — nginx listens on it
PORT=80

# BACKEND_URL: Private network URL of the backend service
BACKEND_URL=http://backend.railway.internal:8000
